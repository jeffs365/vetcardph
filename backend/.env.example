DATABASE_URL="postgresql://vetcard:vetcard@localhost:5433/vetcard?schema=public"
JWT_SECRET="vetcard-local-dev-secret"
COOKIE_SECRET="vetcard-local-cookie-secret"
HOST=0.0.0.0
PORT=3001
CORS_ORIGIN="http://localhost:8080,http://127.0.0.1:8080"
COOKIE_SECURE=false
SERVE_WEB_APP=false
ALLOW_CLINIC_REGISTRATION=true
OWNER_OTP_DELIVERY_MODE=dev-response
PHILSMS_API_TOKEN=
PHILSMS_SENDER_ID=PhilSMS
PHILSMS_API_URL=https://dashboard.philsms.com/api/v3/sms/send

# Optional. When set, pet avatar uploads go to a private Supabase Storage bucket.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=pet-avatars
SUPABASE_STORAGE_SIGNED_URL_SECONDS=3600
